{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crystalline Auto Clicker",
  "version": "1.1.0",
  "identifier": "com.JFK.crystallineautoclicker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Crystalline Auto Clicker",
        "width": 760,
        "height": 680,
        "decorations": false,
        "center": true,
        "visible": false,
        "backgroundColor": "#111111"
      },
      {
        "label": "click-position-overlay",
        "title": "Crystalline Auto Clicker Overlay",
        "url": "overlay.html",
        "width": 1,
        "height": 1,
        "decorations": false,
        "resizable": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "focusable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
